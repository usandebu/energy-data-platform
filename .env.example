# Local raw data root.
RAW_ROOT=data/raw

# Raw storage backend: local or s3.
RAW_STORAGE_BACKEND=local

# S3 raw bucket. Required when RAW_STORAGE_BACKEND=s3.
RAW_BUCKET=

# AEMET OpenData API KEY.
AEMET_API_KEY=

# Project root absolute path.
PROJECT_HOST_ROOT=/absolute/path/to/energy-data-platform

# Airflow local credentials.
AIRFLOW_ADMIN_USERNAME=airflow
AIRFLOW_ADMIN_PASSWORD=airflow
AIRFLOW_ADMIN_FIRSTNAME=Airflow
AIRFLOW_ADMIN_LASTNAME=Admin
AIRFLOW_ADMIN_EMAIL=airflow@example.com

# Airflow metadata database.
AIRFLOW_POSTGRES_USER=airflow
AIRFLOW_POSTGRES_PASSWORD=airflow
AIRFLOW_POSTGRES_DB=airflow

# Local-only webserver secret key.
AIRFLOW_WEBSERVER_SECRET_KEY=local-dev-secret

# Local Fernet key.
AIRFLOW_FERNET_KEY=

# Databricks connection for dbt.
DATABRICKS_HOST=
DATABRICKS_HTTP_PATH=
DATABRICKS_TOKEN=
